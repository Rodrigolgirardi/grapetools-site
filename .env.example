# =============================================================================
#  Grape Tools - modelo de variaveis de ambiente
# =============================================================================
#  COMO USAR:
#  1. Copie este arquivo para ".env.local" (mesma pasta).
#  2. Preencha os valores reais (pegue-os do PC do escritorio ou do
#     gerenciador de senhas). NUNCA coloque os valores reais AQUI neste
#     .env.example -- ele vai pro Git. Os segredos so vao no .env.local,
#     que o .gitignore ja bloqueia.
#  3. Depois de editar o .env.local, REINICIE o servidor (feche e abra o
#     dev.bat) -- variaveis so recarregam ao reiniciar.
# =============================================================================


# --- Supabase (banco de dados + login) --- OBRIGATORIO -----------------------
# Painel: https://supabase.com -> projeto -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Chave de servico (SECRETA, acesso total ao banco). Nunca exponha no frontend.
SUPABASE_SERVICE_ROLE_KEY=


# --- Pagar.me (pagamento) --- OBRIGATORIO ------------------------------------
# Painel: https://dashboard.pagar.me -> Configuracoes -> Chaves
NEXT_PUBLIC_PAGARME_PUBLIC_KEY=
PAGARME_SECRET_KEY=
# Assinatura do webhook (valida que o aviso de pagamento veio mesmo do Pagar.me)
PAGARME_WEBHOOK_SECRET=


# --- Acesso ao painel /admin --- OBRIGATORIO ---------------------------------
# E-mails de administrador separados por virgula (sem espacos).
# Ex.: ADMIN_EMAILS=rodrigolgirardi@gmail.com,socio@grapetools.com.br
ADMIN_EMAILS=


# --- Integracao com o Grape One (API de leitura) --- OBRIGATORIO --------------
# Chave secreta que o Grape One usa pra puxar pedidos/clientes do site.
# Veja docs/API-Grape-One.md
ERP_API_KEY=
# Segredo do cron de reconciliacao de pagamentos (rota /api/cron/reconciliar).
CRON_SECRET=


# --- Sentry (monitoramento de erros) --- OPCIONAL ----------------------------
# Deixe em branco para manter o Sentry "dormente" (zero peso). Preencha so
# quando for ativar. Painel: https://sentry.io
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=


# --- Google Analytics --- OPCIONAL -------------------------------------------
# ID de medicao do GA4 (ex.: G-XXXXXXXXXX). Em branco = sem analytics.
NEXT_PUBLIC_GA_ID=
